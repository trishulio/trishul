<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Or>
        <!-- 1. All framework-style / DI classes -->
        <Class name="~.*(Service|Client|Manager|Provider|Controller|Configuration|Executor|Wrapper|Register|Delegate|Decorator|Repository|Repo|Resolver|Util|Builder|Mapper)" />
        <!-- 2. Entire internal packages where exposure is acceptable -->
        <Class name="~io\.trishul\..*\.(service|client|manager|provider|controller|config|executor|wrapper|delegate|repository)\..*" />
        <!-- 3. Known framework / infra types (instead of Parameter filters) -->
        <Class name="~(javax|jakarta|org\.springframework|com\.amazonaws)\..*" />
        <!-- 4. Models / DTOs (if you want blanket allowance) -->
        <Class name="~io\.trishul\..*\.model\..*" />
    </Or>
</Match>

    <!-- Ignore all bugs for Test Mocks -->
    <Match>
    <Class name="~io\.trishul\.test\..*Mock.*"/>
</Match>

</FindBugsFilter>
